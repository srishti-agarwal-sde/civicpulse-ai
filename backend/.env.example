# Server Config
PORT=5000
NODE_ENV=development

# Database Configuration
# MongoDB Atlas connection string (or local mongodb://localhost:27017/civicpulse)
MONGODB_URI=mongodb://127.0.0.1:27017/civicpulse

# JWT Key configuration (Change in production)
JWT_SECRET=supersecretjwtkey123456

# Gemini API Integration (Get key from Google AI Studio)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Google Cloud Storage Integration (Optional - falls back to local disk storage if empty)
GCS_BUCKET_NAME=your-gcs-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=path-to-your-gcp-keyfile.json
